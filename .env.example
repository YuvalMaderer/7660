# URL of your Google Apps Script Web App (from deploy)
GOOGLE_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Server
PORT=3001
NODE_ENV=production

# Ollama – חילוץ מקומי (ללא API key)
# ollama pull tinyllama      # הכי מהיר ~1GB (מומלץ)
# ollama pull llama3.2:1b    # מהיר מאוד ~1.3GB
# ollama pull qwen2.5:1.5b   # מהיר + עברית טובה ~1GB
# OLLAMA_MODEL=tinyllama     # כפה מודל מסוים
# OLLAMA_KEEP_ALIVE=10m      # שמור מודל טעון (פחות cold start)
# OLLAMA_NUM_THREAD=8        # חוטי CPU (לפי מספר ליבות)
# OLLAMA_HOST=http://ollama:11434  # ב-Docker עם שירות ollama

# Groq – fallback ב-production כשאין Ollama. מפתח חינם: console.groq.com
# GROQ_API_KEY=gsk_xxxxx
